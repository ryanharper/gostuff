        <mxCell id="LfgYDs2PnSeTMkYj1wfz-23" value="&lt;b style=&#39;font-size:16px;color:#f5a623;&#39;&gt;Enterprise Alloy Systems Management&lt;/b&gt;&lt;hr style=&#39;border-color:#495057;&#39;&gt;&lt;ul style=&#39;color:#ced4da; font-size:12px; margin-left:-15px;&#39;&gt;&lt;li&gt;&lt;b style=&#39;color:#e74c3c;&#39;&gt;Red Hat Satellite:&lt;/b&gt; Manages Linux RPMs &amp;amp; Content Views.&lt;/li&gt;&lt;li&gt;&lt;b style=&#39;color:#3498db;&#39;&gt;SCCM / MECM:&lt;/b&gt; Manages Windows MSIs &amp;amp; Rollout Rings.&lt;/li&gt;&lt;li&gt;&lt;b style=&#39;color:#2ecc71;&#39;&gt;Separation of Concerns:&lt;/b&gt; Binary upgrades are pushed via Systems Management. Config is pulled dynamically by Alloy.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1d20;strokeColor=#343a40;fontColor=#ffffff;align=left;spacingLeft=15;spacingTop=10;shadow=1;strokeWidth=2;" vertex="1" parent="1">
